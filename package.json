{
  "name": "shingyong-bed-dashboard",
  "version": "1.0.0",
  "description": "杏永醫院住院動態網頁 — 病床利用情形統計 (前台顯示 + 後台更新)",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "node server.js",
    "fix:accounts:check": "node scripts/fix-orphaned-accounts.js check",
