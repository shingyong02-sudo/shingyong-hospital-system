# 複製這個檔為 .env，並填入你的 Supabase 專案資訊
# （.env 已被 .gitignore 排除，不會上傳到 GitHub）

# Supabase 專案 API URL
SUPABASE_URL=https://xhtnaxwcqqdsdkxjbhvk.supabase.co

# service_role 金鑰（機密！只放本機，切勿提交或分享）
# 取得位置：Supabase Dashboard → Project Settings → API Keys → service_role → Reveal
SUPABASE_SERVICE_ROLE_KEY=在這裡貼上你的_service_role_金鑰

# （選用）伺服器埠號，預設 3100
# PORT=3100
